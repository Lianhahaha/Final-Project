<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.chart.BarChart?>
<?import javafx.scene.chart.CategoryAxis?>
<?import javafx.scene.chart.NumberAxis?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.DatePicker?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.TilePane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>

<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<!--
  CafeMaster · Dashboard
  Root   : AnchorPane  (matches your working layout)
  Sidebar: VBox fixed at left 240 px
  Content: StackPane from left=240 → right=0, only one child visible at a time
  Forms  : inventory_form  (visible by default)
           orders_form     (visible=false)
           reports_form    (visible=false)
           staff_form      (visible=false)
           settings_form   (visible=false)
           dashboard_form  (visible=false – placeholder, kept for safety)
-->
<AnchorPane prefHeight="766.0" prefWidth="1234.0"
            style="-fx-background-color: #EDE8DF;"
            xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.student.cafemaster.DashboardController">
  <children>

    <!-- ═══════════════════════════════════════════════════════════
         SIDEBAR — fixed 240 px  (YOUR ORIGINAL — only logout fixed)
         ═══════════════════════════════════════════════════════════ -->
    <VBox prefWidth="240.0"
          style="-fx-background-color: #1C1008;
                 -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.45), 18, 0, 4, 0);"
          AnchorPane.bottomAnchor="0.0"
          AnchorPane.leftAnchor="0.0"
          AnchorPane.topAnchor="0.0">
      <children>

        <!-- Brand -->
        <VBox alignment="CENTER" prefHeight="148.0" spacing="4"
              style="-fx-background-color: #120B04;
                     -fx-border-color: transparent transparent #2E1F10 transparent;
                     -fx-border-width: 1;">
          <children>
            <Label style="-fx-font-size: 40; -fx-text-fill: #C8922A;
                          -fx-effect: dropshadow(gaussian, rgba(200,146,42,0.6), 12, 0, 0, 0);"
                   text="☕" />
            <Label fx:id="sidebar_shopName"
                   style="-fx-text-fill: #F0E6D3; -fx-font-size: 24;
                          -fx-font-weight: bold; -fx-letter-spacing: 1;" text="CafeMaster">
              <font><Font name="System Bold" size="24.0" /></font>
            </Label>
            <Label style="-fx-text-fill: #6B5440; -fx-font-size: 11;
                          -fx-letter-spacing: 2;" text="Admin Dashboard" />
          </children>
        </VBox>

        <!-- Section label -->
        <Label style="-fx-text-fill: #4A3525; -fx-font-size: 9;
                      -fx-font-weight: bold; -fx-letter-spacing: 2;" text="NAVIGATION">
          <VBox.margin><Insets bottom="6.0" left="20.0" top="22.0" /></VBox.margin>
        </Label>

        <!-- Nav buttons -->
        <VBox spacing="4.0" VBox.vgrow="ALWAYS">
          <padding><Insets left="12.0" right="12.0" /></padding>
          <children>

            <Button fx:id="inventory_btn"
                    maxWidth="1.7976931348623157E308" mnemonicParsing="false"
                    onAction="#switchForm" prefHeight="46.0"
                    style="-fx-background-color: #C8922A; -fx-text-fill: #1C1008;
                           -fx-font-weight: bold; -fx-font-size: 13;
                           -fx-background-radius: 8; -fx-cursor: hand;
                           -fx-alignment: CENTER_LEFT; -fx-padding: 0 0 0 14;
                           -fx-effect: dropshadow(gaussian, rgba(200,146,42,0.4), 10, 0, 0, 3);"
                    text="📦   Inventory" />

            <Button fx:id="orders_btn"
                    maxWidth="1.7976931348623157E308" mnemonicParsing="false"
                    onAction="#switchForm" prefHeight="46.0"
                    style="-fx-background-color: transparent; -fx-text-fill: #9E826A;
                           -fx-font-size: 13; -fx-background-radius: 8; -fx-cursor: hand;
                           -fx-alignment: CENTER_LEFT; -fx-padding: 0 0 0 14;"
                    text="🛒   Orders" />

            <Button fx:id="reports_btn"
                    maxWidth="1.7976931348623157E308" mnemonicParsing="false"
                    onAction="#switchForm" prefHeight="46.0"
                    style="-fx-background-color: transparent; -fx-text-fill: #9E826A;
                           -fx-font-size: 13; -fx-background-radius: 8; -fx-cursor: hand;
                           -fx-alignment: CENTER_LEFT; -fx-padding: 0 0 0 14;"
                    text="📊   Reports" />

            <Button fx:id="staff_btn"
                    maxWidth="1.7976931348623157E308" mnemonicParsing="false"
                    onAction="#switchForm" prefHeight="46.0"
                    style="-fx-background-color: transparent; -fx-text-fill: #9E826A;
                           -fx-font-size: 13; -fx-background-radius: 8; -fx-cursor: hand;
                           -fx-alignment: CENTER_LEFT; -fx-padding: 0 0 0 14;"
                    text="👥   Staff" />

            <Button fx:id="settings_btn"
                    maxWidth="1.7976931348623157E308" mnemonicParsing="false"
                    onAction="#switchForm" prefHeight="46.0"
                    style="-fx-background-color: transparent; -fx-text-fill: #9E826A;
                           -fx-font-size: 13; -fx-background-radius: 8; -fx-cursor: hand;
                           -fx-alignment: CENTER_LEFT; -fx-padding: 0 0 0 14;"
                    text="⚙️   Settings" />

          </children>
        </VBox>

        <!-- Admin chip -->
        <VBox spacing="3"
              style="-fx-background-color: #120B04;
                     -fx-border-color: #2E1F10 transparent transparent transparent;
                     -fx-border-width: 1;">
          <padding><Insets bottom="14.0" left="18.0" right="18.0" top="14.0" /></padding>
          <children>
            <HBox alignment="CENTER_LEFT" spacing="12">
              <children>
                <Label style="-fx-font-size: 28;" text="👤" />
                <VBox spacing="2">
                  <children>
                    <Label fx:id="sidebar_adminName"
                           style="-fx-text-fill: #E8D9C0; -fx-font-weight: bold;
                                  -fx-font-size: 13;" text="Admin User" />
                    <Label fx:id="sidebar_adminRole"
                           style="-fx-text-fill: #4A3525; -fx-font-size: 10;"
                           text="Administrator" />
                  </children>
                </VBox>
              </children>
            </HBox>
          </children>
        </VBox>

        <!-- Logout button — onAction FIXED to call #onLogout -->
        <Button maxWidth="1.7976931348623157E308" mnemonicParsing="false"
                prefHeight="42.0"
                onAction="#onLogout"
                style="-fx-background-color: #6B2213; -fx-text-fill: #F5C6B8;
                       -fx-font-weight: bold; -fx-font-size: 13;
                       -fx-background-radius: 8; -fx-cursor: hand;"
                text="🚪   Logout">
          <VBox.margin><Insets bottom="22.0" left="18.0" right="18.0" top="10.0" /></VBox.margin>
        </Button>

      </children>
    </VBox>


    <!-- ═══════════════════════════════════════════════════════════
         MAIN CONTENT AREA — StackPane, forms stacked, one visible
         ═══════════════════════════════════════════════════════════ -->
    <StackPane AnchorPane.bottomAnchor="0.0"
               AnchorPane.leftAnchor="240.0"
               AnchorPane.rightAnchor="0.0"
               AnchorPane.topAnchor="0.0">
      <children>


        <!-- ─────────────────────────────────────────────────────────
             FORM 1: INVENTORY  (fx:id="inventory_form")
             YOUR ORIGINAL CONTENT — NOT CHANGED
             ───────────────────────────────────────────────────────── -->
        <AnchorPane fx:id="inventory_form">
          <children>

            <!-- Header bar -->
            <HBox alignment="CENTER_LEFT" prefHeight="74.0" spacing="16.0"
                  style="-fx-background-color: #FBF8F3;
                         -fx-border-color: transparent transparent #DDD3C0 transparent;
                         -fx-border-width: 1;
                         -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.06), 12, 0, 0, 4);"
                  AnchorPane.leftAnchor="0.0"
                  AnchorPane.rightAnchor="0.0"
                  AnchorPane.topAnchor="0.0">
              <padding><Insets left="28.0" right="28.0" /></padding>
              <children>
                <VBox spacing="2">
                  <children>
                    <Label style="-fx-font-size: 20; -fx-text-fill: #1C1008;
                                  -fx-font-weight: bold;" text="Inventory Management">
                      <font><Font name="System Bold" size="20.0" /></font>
                    </Label>
                    <Label style="-fx-text-fill: #9E826A; -fx-font-size: 12;"
                           text="Manage your café products and stock levels" />
                  </children>
                </VBox>
                <Region HBox.hgrow="ALWAYS" />
                <!-- Stock legend -->
                <HBox alignment="CENTER" spacing="18">
                  <children>
                    <HBox alignment="CENTER" spacing="5">
                      <children>
                        <Label style="-fx-text-fill: #C0392B; -fx-font-size: 15;
                                      -fx-effect: dropshadow(gaussian,rgba(192,57,43,0.5),6,0,0,0);"
                               text="●" />
                        <Label style="-fx-font-size: 11; -fx-text-fill: #7B6555;"
                               text="Critical ≤5" />
                      </children>
                    </HBox>
                    <HBox alignment="CENTER" spacing="5">
                      <children>
                        <Label style="-fx-text-fill: #D68910; -fx-font-size: 15;
                                      -fx-effect: dropshadow(gaussian,rgba(214,137,16,0.5),6,0,0,0);"
                               text="●" />
                        <Label style="-fx-font-size: 11; -fx-text-fill: #7B6555;"
                               text="Medium ≤15" />
                      </children>
                    </HBox>
                    <HBox alignment="CENTER" spacing="5">
                      <children>
                        <Label style="-fx-text-fill: #1E8449; -fx-font-size: 15;
                                      -fx-effect: dropshadow(gaussian,rgba(30,132,73,0.5),6,0,0,0);"
                               text="●" />
                        <Label style="-fx-font-size: 11; -fx-text-fill: #7B6555;"
                               text="Good &gt;15" />
                      </children>
                    </HBox>
                  </children>
                </HBox>
                <!-- Search -->
                <TextField fx:id="inventory_search" prefHeight="40.0" prefWidth="300.0"
                           promptText="🔍  Search by name, ID or type..."
                           style="-fx-background-color: #F0EAE0;
                                  -fx-border-color: #C8B89A;
                                  -fx-border-radius: 20; -fx-background-radius: 20;
                                  -fx-padding: 0 16 0 16; -fx-font-size: 13;
                                  -fx-text-fill: #2C1C0C;
                                  -fx-prompt-text-fill: #A89070;" />
              </children>
            </HBox>

            <!-- Stat cards -->
            <HBox prefHeight="100.0" spacing="16.0"
                  AnchorPane.leftAnchor="20.0" AnchorPane.rightAnchor="20.0"
                  AnchorPane.topAnchor="90.0">
              <children>
                <!-- Total Products -->
                <HBox maxWidth="1.7976931348623157E308" spacing="0"
                      style="-fx-background-color: #FEFCF8; -fx-background-radius: 12;
                             -fx-border-color: #E0D4C0; -fx-border-radius: 12;
                             -fx-border-width: 1;
                             -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.07), 12, 0, 0, 4);"
                      HBox.hgrow="ALWAYS">
                  <children>
                    <VBox prefWidth="6"
                          style="-fx-background-color: #3182CE;
                                 -fx-background-radius: 12 0 0 12;" />
                    <VBox alignment="CENTER_LEFT" spacing="3" HBox.hgrow="ALWAYS">
                      <padding><Insets bottom="14.0" left="16.0" right="16.0" top="14.0" /></padding>
                      <children>
                        <Label style="-fx-font-size: 20;" text="📦" />
                        <Label fx:id="dashboard_totalProducts"
                               style="-fx-font-size: 30; -fx-text-fill: #3182CE;
                                      -fx-font-weight: bold;" text="0">
                          <font><Font name="System Bold" size="30.0" /></font>
                        </Label>
                        <Label style="-fx-text-fill: #9E826A; -fx-font-size: 11;"
                               text="Total Products" />
                      </children>
                    </VBox>
                  </children>
                </HBox>
                <!-- Critical Stock -->
                <HBox maxWidth="1.7976931348623157E308" spacing="0"
                      style="-fx-background-color: #FEFCF8; -fx-background-radius: 12;
                             -fx-border-color: #E0D4C0; -fx-border-radius: 12;
                             -fx-border-width: 1;
                             -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.07), 12, 0, 0, 4);"
                      HBox.hgrow="ALWAYS">
                  <children>
                    <VBox prefWidth="6"
                          style="-fx-background-color: #C0392B;
                                 -fx-background-radius: 12 0 0 12;" />
                    <VBox alignment="CENTER_LEFT" spacing="3" HBox.hgrow="ALWAYS">
                      <padding><Insets bottom="14.0" left="16.0" right="16.0" top="14.0" /></padding>
                      <children>
                        <Label style="-fx-font-size: 20;" text="⚠️" />
                        <Label fx:id="dashboard_criticalStock"
                               style="-fx-font-size: 30; -fx-text-fill: #C0392B;
                                      -fx-font-weight: bold;" text="0">
                          <font><Font name="System Bold" size="30.0" /></font>
                        </Label>
                        <Label style="-fx-text-fill: #9E826A; -fx-font-size: 11;"
                               text="Critical Stock (≤5)" />
                      </children>
                    </VBox>
                  </children>
                </HBox>
                <!-- Medium Stock -->
                <HBox maxWidth="1.7976931348623157E308" spacing="0"
                      style="-fx-background-color: #FEFCF8; -fx-background-radius: 12;
                             -fx-border-color: #E0D4C0; -fx-border-radius: 12;
                             -fx-border-width: 1;
                             -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.07), 12, 0, 0, 4);"
                      HBox.hgrow="ALWAYS">
                  <children>
                    <VBox prefWidth="6"
                          style="-fx-background-color: #D68910;
                                 -fx-background-radius: 12 0 0 12;" />
                    <VBox alignment="CENTER_LEFT" spacing="3" HBox.hgrow="ALWAYS">
                      <padding><Insets bottom="14.0" left="16.0" right="16.0" top="14.0" /></padding>
                      <children>
                        <Label style="-fx-font-size: 20;" text="📊" />
                        <Label fx:id="dashboard_mediumStock"
                               style="-fx-font-size: 30; -fx-text-fill: #D68910;
                                      -fx-font-weight: bold;" text="0">
                          <font><Font name="System Bold" size="30.0" /></font>
                        </Label>
                        <Label style="-fx-text-fill: #9E826A; -fx-font-size: 11;"
                               text="Medium Stock (≤15)" />
                      </children>
                    </VBox>
                  </children>
                </HBox>
                <!-- Inventory Value -->
                <HBox maxWidth="1.7976931348623157E308" spacing="0"
                      style="-fx-background-color: #FEFCF8; -fx-background-radius: 12;
                             -fx-border-color: #E0D4C0; -fx-border-radius: 12;
                             -fx-border-width: 1;
                             -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.07), 12, 0, 0, 4);"
                      HBox.hgrow="ALWAYS">
                  <children>
                    <VBox prefWidth="6"
                          style="-fx-background-color: #1E8449;
                                 -fx-background-radius: 12 0 0 12;" />
                    <VBox alignment="CENTER_LEFT" spacing="3" HBox.hgrow="ALWAYS">
                      <padding><Insets bottom="14.0" left="16.0" right="16.0" top="14.0" /></padding>
                      <children>
                        <Label style="-fx-font-size: 20;" text="💰" />
                        <Label fx:id="dashboard_inventoryValue"
                               style="-fx-font-size: 22; -fx-text-fill: #1E8449;
                                      -fx-font-weight: bold;" text="₱0.00">
                          <font><Font name="System Bold" size="22.0" /></font>
                        </Label>
                        <Label style="-fx-text-fill: #9E826A; -fx-font-size: 11;"
                               text="Inventory Value" />
                      </children>
                    </VBox>
                  </children>
                </HBox>
              </children>
            </HBox>

            <!-- Form + Table row -->
            <HBox spacing="16.0"
                  AnchorPane.bottomAnchor="50.0" AnchorPane.leftAnchor="20.0"
                  AnchorPane.rightAnchor="20.0"  AnchorPane.topAnchor="206.0">
              <children>

                <!-- Product Details form -->
                <VBox prefWidth="295.0" spacing="11.0"
                      style="-fx-background-color: #FEFCF8; -fx-background-radius: 12;
                             -fx-border-color: #DDD3C0; -fx-border-radius: 12;
                             -fx-border-width: 1;
                             -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.08), 14, 0, 0, 4);">
                  <padding><Insets bottom="22.0" left="22.0" right="22.0" top="22.0" /></padding>
                  <children>
                    <HBox alignment="CENTER_LEFT" spacing="8">
                      <children>
                        <Label style="-fx-font-size: 17;" text="📝" />
                        <Label style="-fx-font-size: 15; -fx-text-fill: #1C1008;
                                      -fx-font-weight: bold;" text="Product Details">
                          <font><Font name="System Bold" size="15.0" /></font>
                        </Label>
                      </children>
                    </HBox>
                    <Separator style="-fx-background-color: #DDD3C0;" />
                    <!-- Product ID -->
                    <VBox spacing="4">
                      <children>
                        <Label style="-fx-text-fill: #5A4030; -fx-font-size: 11;
                                      -fx-font-weight: bold;" text="Product ID" />
                        <TextField fx:id="inventory_productID" prefHeight="38.0"
                                   promptText="e.g.  101"
                                   style="-fx-background-color: #F5F0E8;
                                          -fx-border-color: #C8B89A; -fx-border-radius: 7;
                                          -fx-background-radius: 7; -fx-padding: 0 12 0 12;
                                          -fx-font-size: 13; -fx-text-fill: #1C1008;
                                          -fx-prompt-text-fill: #B8A080;" />
                      </children>
                    </VBox>
                    <!-- Product Name -->
                    <VBox spacing="4">
                      <children>
                        <Label style="-fx-text-fill: #5A4030; -fx-font-size: 11;
                                      -fx-font-weight: bold;" text="Product Name" />
                        <TextField fx:id="inventory_productName" prefHeight="38.0"
                                   promptText="e.g.  Espresso"
                                   style="-fx-background-color: #F5F0E8;
                                          -fx-border-color: #C8B89A; -fx-border-radius: 7;
                                          -fx-background-radius: 7; -fx-padding: 0 12 0 12;
                                          -fx-font-size: 13; -fx-text-fill: #1C1008;
                                          -fx-prompt-text-fill: #B8A080;" />
                      </children>
                    </VBox>
                    <!-- Type -->
                    <VBox spacing="4">
                      <children>
                        <Label style="-fx-text-fill: #5A4030; -fx-font-size: 11;
                                      -fx-font-weight: bold;" text="Type" />
                        <TextField fx:id="inventory_type" prefHeight="38.0"
                                   promptText="e.g.  Beverage / Pastry"
                                   style="-fx-background-color: #F5F0E8;
                                          -fx-border-color: #C8B89A; -fx-border-radius: 7;
                                          -fx-background-radius: 7; -fx-padding: 0 12 0 12;
                                          -fx-font-size: 13; -fx-text-fill: #1C1008;
                                          -fx-prompt-text-fill: #B8A080;" />
                      </children>
                    </VBox>
                    <!-- Stock + Price -->
                    <HBox spacing="10">
                      <children>
                        <VBox spacing="4" HBox.hgrow="ALWAYS">
                          <children>
                            <Label style="-fx-text-fill: #5A4030; -fx-font-size: 11;
                                          -fx-font-weight: bold;" text="Stock (qty)" />
                            <TextField fx:id="inventory_stock" prefHeight="38.0"
                                       promptText="0"
                                       style="-fx-background-color: #F5F0E8;
                                              -fx-border-color: #C8B89A; -fx-border-radius: 7;
                                              -fx-background-radius: 7; -fx-padding: 0 12 0 12;
                                              -fx-font-size: 13; -fx-text-fill: #1C1008;
                                              -fx-prompt-text-fill: #B8A080;" />
                          </children>
                        </VBox>
                        <VBox spacing="4" HBox.hgrow="ALWAYS">
                          <children>
                            <Label style="-fx-text-fill: #5A4030; -fx-font-size: 11;
                                          -fx-font-weight: bold;" text="Price (₱)" />
                            <TextField fx:id="inventory_price" prefHeight="38.0"
                                       promptText="0.00"
                                       style="-fx-background-color: #F5F0E8;
                                              -fx-border-color: #C8B89A; -fx-border-radius: 7;
                                              -fx-background-radius: 7; -fx-padding: 0 12 0 12;
                                              -fx-font-size: 13; -fx-text-fill: #1C1008;
                                              -fx-prompt-text-fill: #B8A080;" />
                          </children>
                        </VBox>
                      </children>
                    </HBox>
                    <Region VBox.vgrow="ALWAYS" />
                    <Separator style="-fx-background-color: #DDD3C0;" />
                    <!-- ADD -->
                    <Button fx:id="inventory_addBtn"
                            maxWidth="1.7976931348623157E308" mnemonicParsing="false"
                            onAction="#inventoryAddBtn" prefHeight="44.0"
                            style="-fx-background-color: #1E8449; -fx-text-fill: white;
                                   -fx-font-weight: bold; -fx-font-size: 13;
                                   -fx-background-radius: 8; -fx-cursor: hand;
                                   -fx-effect: dropshadow(gaussian, rgba(30,132,73,0.4), 10, 0, 0, 3);"
                            text="➕   ADD PRODUCT" />
                    <!-- UPDATE + DELETE -->
                    <HBox spacing="10.0">
                      <children>
                        <Button fx:id="inventory_updateBtn"
                                maxWidth="1.7976931348623157E308" mnemonicParsing="false"
                                onAction="#inventoryUpdateBtn" prefHeight="42.0"
                                style="-fx-background-color: #1A5276; -fx-text-fill: white;
                                       -fx-font-weight: bold; -fx-font-size: 12;
                                       -fx-background-radius: 8; -fx-cursor: hand;
                                       -fx-effect: dropshadow(gaussian, rgba(26,82,118,0.4), 10, 0, 0, 3);"
                                text="✏️  UPDATE" HBox.hgrow="ALWAYS" />
                        <Button fx:id="inventory_deleteBtn"
                                maxWidth="1.7976931348623157E308" mnemonicParsing="false"
                                onAction="#inventoryDeleteBtn" prefHeight="42.0"
                                style="-fx-background-color: #922B21; -fx-text-fill: white;
                                       -fx-font-weight: bold; -fx-font-size: 12;
                                       -fx-background-radius: 8; -fx-cursor: hand;
                                       -fx-effect: dropshadow(gaussian, rgba(146,43,33,0.4), 10, 0, 0, 3);"
                                text="🗑️  DELETE" HBox.hgrow="ALWAYS" />
                      </children>
                    </HBox>
                    <!-- CLEAR -->
                    <Button fx:id="inventory_clearBtn"
                            maxWidth="1.7976931348623157E308" mnemonicParsing="false"
                            onAction="#inventoryClearBtn" prefHeight="36.0"
                            style="-fx-background-color: #F0EAE0; -fx-text-fill: #5A4030;
                                   -fx-font-size: 11; -fx-font-weight: bold;
                                   -fx-background-radius: 8; -fx-cursor: hand;
                                   -fx-border-color: #C8B89A; -fx-border-radius: 8;
                                   -fx-border-width: 1;"
                            text="✖   CLEAR FORM" />
                  </children>
                </VBox>

                <!-- Product List table -->
                <VBox style="-fx-background-color: #FEFCF8; -fx-background-radius: 12;
                             -fx-border-color: #DDD3C0; -fx-border-radius: 12;
                             -fx-border-width: 1;
