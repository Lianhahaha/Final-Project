                                      -fx-font-weight: bold;" text="Sales Revenue by Product">
                          <font><Font name="System Bold" size="14.0" /></font>
                        </Label>
                      </children>
                    </HBox>
                    <BarChart fx:id="reports_salesChart" VBox.vgrow="ALWAYS"
                              animated="true"
                              style="-fx-background-color: transparent;">
                      <xAxis>
                        <CategoryAxis fx:id="reports_salesXAxis" label="Product" />
                      </xAxis>
                      <yAxis>
                        <NumberAxis fx:id="reports_salesYAxis" label="Revenue (₱)" />
                      </yAxis>
                    </BarChart>
                  </children>
                </VBox>

              </children>
            </HBox>

          </children>
        </AnchorPane>
        <!-- END: reports_form -->


        <!-- ═══════════════════════════════════════════════════════════
             FORM 5: STAFF  (fx:id="staff_form")
             Left = add form  |  Right = staff table
             ═══════════════════════════════════════════════════════════ -->
        <AnchorPane fx:id="staff_form" visible="false">
          <children>

            <!-- Header -->
            <HBox alignment="CENTER_LEFT" spacing="16.0" prefHeight="74.0"
                  style="-fx-background-color: #FBF8F3;
                         -fx-border-color: transparent transparent #DDD3C0 transparent;
                         -fx-border-width: 1;
                         -fx-effect: dropshadow(gaussian,rgba(0,0,0,0.06),12,0,0,4);"
                  AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0"
                  AnchorPane.topAnchor="0.0">
              <padding><Insets left="28.0" right="28.0" /></padding>
              <children>
                <VBox spacing="2">
                  <children>
                    <Label style="-fx-font-size: 20; -fx-text-fill: #1C1008;
                                  -fx-font-weight: bold;" text="Staff Management">
                      <font><Font name="System Bold" size="20.0" /></font>
                    </Label>
                    <Label style="-fx-text-fill: #9E826A; -fx-font-size: 12;"
                           text="Manage your café team members and roles" />
                  </children>
                </VBox>
                <Region HBox.hgrow="ALWAYS" />
                <Label fx:id="staff_countLabel" text="0 staff members"
                       style="-fx-text-fill: #9E826A; -fx-font-size: 12;
                              -fx-background-color: #EDE8DF; -fx-background-radius: 20;
                              -fx-padding: 4 12 4 12;" />
              </children>
            </HBox>

            <!-- Body -->
            <HBox spacing="16.0"
                  AnchorPane.leftAnchor="20.0"  AnchorPane.rightAnchor="20.0"
                  AnchorPane.topAnchor="90.0"   AnchorPane.bottomAnchor="20.0">
              <children>

                <!-- Add Staff form -->
                <VBox spacing="11.0" prefWidth="280.0"
                      style="-fx-background-color: #FEFCF8; -fx-background-radius: 12;
                             -fx-border-color: #DDD3C0; -fx-border-radius: 12;
                             -fx-border-width: 1;
                             -fx-effect: dropshadow(gaussian,rgba(0,0,0,0.08),14,0,0,4);">
                  <padding><Insets top="22.0" bottom="22.0" left="22.0" right="22.0" /></padding>
                  <children>
                    <HBox alignment="CENTER_LEFT" spacing="8">
                      <children>
                        <Label style="-fx-font-size: 16;" text="👤" />
                        <Label style="-fx-font-size: 14; -fx-text-fill: #1C1008;
                                      -fx-font-weight: bold;" text="Add Staff Member">
                          <font><Font name="System Bold" size="14.0" /></font>
                        </Label>
                      </children>
                    </HBox>
                    <Separator style="-fx-background-color: #DDD3C0;" />
                    <!-- Name -->
                    <VBox spacing="4">
                      <children>
                        <Label style="-fx-text-fill: #5A4030; -fx-font-size: 11;
                                      -fx-font-weight: bold;" text="Full Name" />
                        <TextField fx:id="staff_nameField" prefHeight="38.0"
                                   promptText="e.g. Maria Santos"
                                   style="-fx-background-color: #F5F0E8;
                                          -fx-border-color: #C8B89A; -fx-border-radius: 7;
                                          -fx-background-radius: 7; -fx-padding: 0 12 0 12;
                                          -fx-font-size: 13; -fx-text-fill: #1C1008;
                                          -fx-prompt-text-fill: #B8A080;" />
                      </children>
                    </VBox>
                    <!-- Role combo -->
                    <VBox spacing="4">
                      <children>
                        <Label style="-fx-text-fill: #5A4030; -fx-font-size: 11;
                                      -fx-font-weight: bold;" text="Role" />
                        <ComboBox fx:id="staff_roleCombo"
                                  maxWidth="1.7976931348623157E308"
                                  promptText="Select role..."
                                  style="-fx-background-color: #F5F0E8;
                                         -fx-border-color: #C8B89A; -fx-border-radius: 7;
                                         -fx-background-radius: 7; -fx-font-size: 13;" />
                      </children>
                    </VBox>
                    <Region VBox.vgrow="ALWAYS" />
                    <Separator style="-fx-background-color: #DDD3C0;" />
                    <Button maxWidth="1.7976931348623157E308" prefHeight="44.0"
                            text="➕   ADD STAFF" onAction="#onAddStaff"
                            mnemonicParsing="false"
                            style="-fx-background-color: #1E8449; -fx-text-fill: white;
                                   -fx-font-weight: bold; -fx-font-size: 13;
                                   -fx-background-radius: 8; -fx-cursor: hand;
                                   -fx-effect: dropshadow(gaussian,rgba(30,132,73,0.4),10,0,0,3);" />
                    <Button maxWidth="1.7976931348623157E308" prefHeight="42.0"
                            text="🗑️  REMOVE SELECTED" onAction="#onRemoveStaff"
                            mnemonicParsing="false"
                            style="-fx-background-color: #922B21; -fx-text-fill: white;
                                   -fx-font-weight: bold; -fx-font-size: 12;
                                   -fx-background-radius: 8; -fx-cursor: hand;
                                   -fx-effect: dropshadow(gaussian,rgba(146,43,33,0.4),10,0,0,3);" />
                  </children>
                </VBox>

                <!-- Staff table -->
                <VBox HBox.hgrow="ALWAYS"
                      style="-fx-background-color: #FEFCF8; -fx-background-radius: 12;
                             -fx-border-color: #DDD3C0; -fx-border-radius: 12;
                             -fx-border-width: 1;
                             -fx-effect: dropshadow(gaussian,rgba(0,0,0,0.08),14,0,0,4);">
                  <children>
                    <HBox alignment="CENTER_LEFT" prefHeight="52.0" spacing="10"
                          style="-fx-background-color: #F5F0E8;
                                 -fx-background-radius: 12 12 0 0;
                                 -fx-border-color: transparent transparent #DDD3C0 transparent;
                                 -fx-border-width: 1;">
                      <padding><Insets left="22.0" right="22.0" /></padding>
                      <children>
                        <Label style="-fx-font-size: 16;" text="👥" />
                        <Label style="-fx-font-size: 14; -fx-text-fill: #1C1008;
                                      -fx-font-weight: bold;" text="Staff List">
                          <font><Font name="System Bold" size="14.0" /></font>
                        </Label>
                      </children>
                    </HBox>
                    <TableView fx:id="staff_tableView" VBox.vgrow="ALWAYS"
                               style="-fx-background-color: transparent;
                                      -fx-border-color: transparent;
                                      -fx-table-cell-border-color: #EDE8DF;">
                      <columns>
                        <TableColumn fx:id="staff_col_name"   text="Name"   prefWidth="200.0" />
                        <TableColumn fx:id="staff_col_role"   text="Role"   prefWidth="150.0" />
                        <TableColumn fx:id="staff_col_status" text="Status" prefWidth="120.0" />
                      </columns>
                      <columnResizePolicy>
                        <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                      </columnResizePolicy>
                    </TableView>
                  </children>
                </VBox>

              </children>
            </HBox>

          </children>
        </AnchorPane>
        <!-- END: staff_form -->


        <!-- ═══════════════════════════════════════════════════════════
             FORM 6: SETTINGS  (fx:id="settings_form")
             Shop info fields + Save + Logout
             ═══════════════════════════════════════════════════════════ -->
        <AnchorPane fx:id="settings_form" visible="false">
          <children>

            <!-- Header -->
            <HBox alignment="CENTER_LEFT" spacing="16.0" prefHeight="74.0"
                  style="-fx-background-color: #FBF8F3;
                         -fx-border-color: transparent transparent #DDD3C0 transparent;
                         -fx-border-width: 1;
                         -fx-effect: dropshadow(gaussian,rgba(0,0,0,0.06),12,0,0,4);"
                  AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0"
                  AnchorPane.topAnchor="0.0">
              <padding><Insets left="28.0" right="28.0" /></padding>
              <children>
                <VBox spacing="2">
                  <children>
                    <Label style="-fx-font-size: 20; -fx-text-fill: #1C1008;
                                  -fx-font-weight: bold;" text="Settings">
                      <font><Font name="System Bold" size="20.0" /></font>
                    </Label>
                    <Label style="-fx-text-fill: #9E826A; -fx-font-size: 12;"
                           text="Configure your CafeMaster application" />
                  </children>
                </VBox>
              </children>
            </HBox>

            <!-- Settings card -->
            <VBox spacing="14.0"
                  AnchorPane.leftAnchor="40.0"  AnchorPane.rightAnchor="40.0"
                  AnchorPane.topAnchor="100.0"  AnchorPane.bottomAnchor="40.0"
                  style="-fx-background-color: #FEFCF8; -fx-background-radius: 14;
                         -fx-border-color: #DDD3C0; -fx-border-radius: 14;
                         -fx-border-width: 1;
                         -fx-effect: dropshadow(gaussian,rgba(0,0,0,0.08),14,0,0,4);">
              <padding><Insets top="30.0" bottom="30.0" left="36.0" right="36.0" /></padding>
              <children>
                <HBox alignment="CENTER_LEFT" spacing="10">
                  <children>
                    <Label style="-fx-font-size: 22;" text="⚙️" />
                    <Label style="-fx-font-size: 17; -fx-text-fill: #1C1008;
                                  -fx-font-weight: bold;" text="Shop Settings">
                      <font><Font name="System Bold" size="17.0" /></font>
                    </Label>
                  </children>
                </HBox>
                <Separator style="-fx-background-color: #DDD3C0;" />
                <!-- Shop Name -->
                <VBox spacing="6">
                  <children>
                    <Label style="-fx-text-fill: #5A4030; -fx-font-size: 12;
                                  -fx-font-weight: bold;" text="Shop Name" />
                    <TextField fx:id="settings_shopName" prefHeight="42.0"
                               promptText="e.g.  CafeMaster"
                               style="-fx-background-color: #F5F0E8;
                                      -fx-border-color: #C8B89A; -fx-border-radius: 8;
                                      -fx-background-radius: 8; -fx-padding: 0 14 0 14;
                                      -fx-font-size: 14; -fx-text-fill: #1C1008;
                                      -fx-prompt-text-fill: #B8A080;" />
                  </children>
                </VBox>
                <!-- Admin Name -->
                <VBox spacing="6">
                  <children>
                    <Label style="-fx-text-fill: #5A4030; -fx-font-size: 12;
                                  -fx-font-weight: bold;" text="Admin Name" />
                    <TextField fx:id="settings_adminName" prefHeight="42.0"
                               promptText="e.g.  Admin User"
                               style="-fx-background-color: #F5F0E8;
                                      -fx-border-color: #C8B89A; -fx-border-radius: 8;
                                      -fx-background-radius: 8; -fx-padding: 0 14 0 14;
                                      -fx-font-size: 14; -fx-text-fill: #1C1008;
                                      -fx-prompt-text-fill: #B8A080;" />
                  </children>
                </VBox>
                <!-- DB URL (read-only) -->
                <VBox spacing="6">
                  <children>
                    <Label style="-fx-text-fill: #5A4030; -fx-font-size: 12;
                                  -fx-font-weight: bold;" text="Database URL  (read-only)" />
                    <TextField fx:id="settings_dbUrl" prefHeight="42.0"
                               text="jdbc:mysql://localhost:3306/CafeMaster"
                               editable="false"
                               style="-fx-background-color: #EDE8DF;
                                      -fx-border-color: #C8B89A; -fx-border-radius: 8;
                                      -fx-background-radius: 8; -fx-padding: 0 14 0 14;
                                      -fx-font-size: 13; -fx-text-fill: #7B6555;" />
                  </children>
                </VBox>
                <Region VBox.vgrow="ALWAYS" />
                <Separator style="-fx-background-color: #DDD3C0;" />
                <!-- Action row -->
                <HBox spacing="12.0">
                  <children>
                    <Button text="💾   SAVE SETTINGS" onAction="#onSaveSettings"
                            mnemonicParsing="false" prefHeight="44.0"
                            HBox.hgrow="ALWAYS" maxWidth="1.7976931348623157E308"
                            style="-fx-background-color: #C8922A; -fx-text-fill: #1C1008;
                                   -fx-font-weight: bold; -fx-font-size: 13;
                                   -fx-background-radius: 8; -fx-cursor: hand;
                                   -fx-effect: dropshadow(gaussian,rgba(200,146,42,0.4),10,0,0,3);" />
                    <Button fx:id="settings_logoutBtn"
                            text="🚪   LOGOUT" onAction="#onLogout"
                            mnemonicParsing="false" prefHeight="44.0"
                            HBox.hgrow="ALWAYS" maxWidth="1.7976931348623157E308"
                            style="-fx-background-color: #6B2213; -fx-text-fill: #F5C6B8;
                                   -fx-font-weight: bold; -fx-font-size: 13;
                                   -fx-background-radius: 8; -fx-cursor: hand;" />
                  </children>
                </HBox>
              </children>
            </VBox>

          </children>
        </AnchorPane>
        <!-- END: settings_form -->


      </children>
    </StackPane>

  </children>
</AnchorPane>
