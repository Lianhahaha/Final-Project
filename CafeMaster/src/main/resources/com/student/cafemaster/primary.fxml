<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<AnchorPane prefHeight="600.0" prefWidth="800.0" style="-fx-background-color: #f0f2f5;" xmlns="http://javafx.com/javafx/25" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.student.cafemaster.PrimaryController">
   <children>
      <VBox alignment="CENTER" layoutX="110.0" layoutY="30.0" prefHeight="502.0" prefWidth="609.0" spacing="20.0" style="-fx-background-color: white; -fx-background-radius: 15; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.1), 10, 0, 0, 5);" AnchorPane.bottomAnchor="30.0" AnchorPane.leftAnchor="110.0" AnchorPane.rightAnchor="110.0" AnchorPane.topAnchor="30.0">
         <children>
            <Label text="CafeMaster" textFill="#2c3e50">
               <font>
                  <Font name="Kristen ITC" size="48.0" />
               </font>
            </Label>
            <Label text="Please login to continue" textFill="#7f8c8d">
               <font>
                  <Font size="14.0" />
               </font></Label>
            <VBox alignment="CENTER" spacing="10.0">
               <children>
                  <TextField fx:id="usernameField" maxHeight="40.0" maxWidth="350.0" prefHeight="40.0" prefWidth="748.0" promptText="Username" style="-fx-background-radius: 5;" />
                  <PasswordField fx:id="passwordField" maxHeight="40.0" maxWidth="350.0" prefHeight="40.0" prefWidth="351.0" promptText="Password" style="-fx-background-radius: 5;" />
               </children>
               <VBox.margin>
                  <Insets left="20.0" right="20.0" />
               </VBox.margin>
            </VBox>
            <Button fx:id="loginBtn" maxHeight="40.0" maxWidth="160.0" mnemonicParsing="false" onAction="#handleLogin" prefHeight="40.0" prefWidth="260.0" style="-fx-background-color: #2ecc71; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 5; -fx-cursor: hand;" text="LOGIN" />
            <Label fx:id="errorLabel" textFill="#e74c3c" />
         </children>
      </VBox>
   </children>
</AnchorPane>
